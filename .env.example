# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM API (using Groq - free & fast!)
OPENAI_API_KEY=your_groq_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# News API Keys
NEWSAPI_KEY=your_newsapi_key_here

# CoinGecko (free, no key needed for basic)
# COINGECKO_API_KEY=optional

# Scheduler timezone
TIMEZONE=Asia/Jakarta

# Channel auto-post (add bot as admin to channel first!)
# Use @channel_username or numeric ID like -1001234567890
CHANNEL_ID=@YourChannelUsername
CHANNEL_LANGUAGE=en

# Force Join — Users must join this channel to use the bot
# Set channel username WITHOUT @ (e.g., MyCryptoChannel)
FORCE_JOIN_CHANNEL=YourChannelUsername

# Default language (en or id)
DEFAULT_LANGUAGE=en
